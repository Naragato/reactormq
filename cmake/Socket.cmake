# Base defaults

set(_REACTORMQ_WITH_O3DE_SOCKET_DEFAULT 0)
set(_REACTORMQ_WITH_FSOCKET_UE5_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_WEBSOCKET_UE5_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_SONY_SOCKET_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_LIB_WEBSOCKET_DEFAULT 1)

set(_REACTORMQ_SOCKET_WITH_POSIX_SOCKET_DEFAULT 1)
set(_REACTORMQ_SOCKET_WITH_IOCTL_DEFAULT 1)
set(_REACTORMQ_SOCKET_WITH_POLL_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_SELECT_DEFAULT 1)
set(_REACTORMQ_SOCKET_WITH_WINSOCKET_DEFAULT 0)

set(_REACTORMQ_SOCKET_WITH_GETHOSTNAME_DEFAULT 1)
set(_REACTORMQ_SOCKET_WITH_GETADDRINFO_DEFAULT 1)
set(_REACTORMQ_SOCKET_WITH_GETNAMEINFO_DEFAULT 1)

set(_REACTORMQ_SOCKET_WITH_CLOSE_ON_EXEC_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_RECVMMSG_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_TIMESTAMP_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_NODELAY_DEFAULT 1)

set(_REACTORMQ_PLATFORM_HAS_BSD_TIME_DEFAULT 0)
set(_REACTORMQ_PLATFORM_HAS_BSD_IPV6_SOCKETS_DEFAULT 0)

# Platform-specific overrides (adjust *_DEFAULT values only)

if (REACTORMQ_PLATFORM_ANDROID)
    set(_REACTORMQ_SOCKET_WITH_IOCTL_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT 1)
endif ()

if (REACTORMQ_PLATFORM_DARWIN_FAMILY)
    set(_REACTORMQ_PLATFORM_HAS_BSD_TIME_DEFAULT 1)
    set(_REACTORMQ_PLATFORM_HAS_BSD_IPV6_SOCKETS_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT 1)
endif ()

if (REACTORMQ_PLATFORM_LINUX)
    set(_REACTORMQ_PLATFORM_HAS_BSD_IPV6_SOCKETS_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_IOCTL_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_POLL_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_RECVMMSG_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_TIMESTAMP_DEFAULT 1)
endif ()

if (REACTORMQ_PLATFORM_PROSPERO)
    set(_REACTORMQ_SOCKET_WITH_GETHOSTNAME_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_GETADDRINFO_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_GETNAMEINFO_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_SELECT_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_IOCTL_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_POSIX_SOCKET_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_SONY_SOCKET_DEFAULT 1)
endif ()

if (REACTORMQ_PLATFORM_WINDOWS_FAMILY)
    set(_REACTORMQ_SOCKET_WITH_WINSOCKET_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_POSIX_SOCKET_DEFAULT 0)
endif ()

if (REACTORMQ_IN_O3DE_GEM)
    set(_REACTORMQ_WITH_O3DE_SOCKET_DEFAULT 1)
    set(_REACTORMQ_SOCKET_WITH_WINSOCKET_DEFAULT 0)
    set(_REACTORMQ_SOCKET_WITH_POSIX_SOCKET_DEFAULT 0)
endif ()

# Options

option(REACTORMQ_WITH_O3DE_SOCKET "Use O3DE socket backend" ${_REACTORMQ_WITH_O3DE_SOCKET_DEFAULT})
option(REACTORMQ_WITH_FSOCKET_UE5 "Use UE5 FSocket backend" ${_REACTORMQ_WITH_FSOCKET_UE5_DEFAULT})
option(REACTORMQ_SOCKET_WITH_WEBSOCKET_UE5 "Use UE5 WebSocket backend" ${_REACTORMQ_SOCKET_WITH_WEBSOCKET_UE5_DEFAULT})
option(REACTORMQ_SOCKET_WITH_SONY_SOCKET "Enable Sony socket support" ${_REACTORMQ_SOCKET_WITH_SONY_SOCKET_DEFAULT})
option(REACTORMQ_SOCKET_WITH_LIB_WEBSOCKET "Use libwebsocket" ${_REACTORMQ_SOCKET_WITH_LIB_WEBSOCKET_DEFAULT})
option(REACTORMQ_SOCKET_WITH_POSIX_SOCKET "Enable POSIX socket support" ${_REACTORMQ_SOCKET_WITH_POSIX_SOCKET_DEFAULT})
option(REACTORMQ_SOCKET_WITH_IOCTL "Use ioctl() on sockets" ${_REACTORMQ_SOCKET_WITH_IOCTL_DEFAULT})
option(REACTORMQ_SOCKET_WITH_POLL "Use poll()" ${_REACTORMQ_SOCKET_WITH_POLL_DEFAULT})
option(REACTORMQ_SOCKET_WITH_SELECT "Use select()" ${_REACTORMQ_SOCKET_WITH_SELECT_DEFAULT})
option(REACTORMQ_SOCKET_WITH_WINSOCKET "Enable WinSock support" ${_REACTORMQ_SOCKET_WITH_WINSOCKET_DEFAULT})
option(REACTORMQ_SOCKET_WITH_GETHOSTNAME "Use gethostname()" ${_REACTORMQ_SOCKET_WITH_GETHOSTNAME_DEFAULT})
option(REACTORMQ_SOCKET_WITH_GETADDRINFO "Use getaddrinfo()" ${_REACTORMQ_SOCKET_WITH_GETADDRINFO_DEFAULT})
option(REACTORMQ_SOCKET_WITH_GETNAMEINFO "Use getnameinfo()" ${_REACTORMQ_SOCKET_WITH_GETNAMEINFO_DEFAULT})
option(REACTORMQ_SOCKET_WITH_CLOSE_ON_EXEC "Support close-on-exec flag" ${_REACTORMQ_SOCKET_WITH_CLOSE_ON_EXEC_DEFAULT})
option(REACTORMQ_SOCKET_WITH_MSG_DONTWAIT "Use MSG_DONTWAIT flag" ${_REACTORMQ_SOCKET_WITH_MSG_DONTWAIT_DEFAULT})
option(REACTORMQ_SOCKET_WITH_RECVMMSG "Use recvmmsg()" ${_REACTORMQ_SOCKET_WITH_RECVMMSG_DEFAULT})
option(REACTORMQ_SOCKET_WITH_TIMESTAMP "Use socket timestamping" ${_REACTORMQ_SOCKET_WITH_TIMESTAMP_DEFAULT})
option(REACTORMQ_SOCKET_WITH_NODELAY "Enable TCP_NODELAY" ${_REACTORMQ_SOCKET_WITH_NODELAY_DEFAULT})
option(REACTORMQ_PLATFORM_HAS_BSD_TIME "Platform has BSD time APIs" ${_REACTORMQ_PLATFORM_HAS_BSD_TIME_DEFAULT})
option(REACTORMQ_PLATFORM_HAS_BSD_IPV6_SOCKETS "Platform has BSD IPv6 sockets" ${_REACTORMQ_PLATFORM_HAS_BSD_IPV6_SOCKETS_DEFAULT})

set(_REACTORMQ_SECURE_SOCKET_WITH_TLS_DEFAULT OFF)
set(_REACTORMQ_SECURE_SOCKET_WITH_BIO_TLS_DEFAULT OFF)

set(_REACTORMQ_WITH_O3DE_SOCKET_DEFAULT 0)
set(_REACTORMQ_WITH_FSOCKET_UE5_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_WEBSOCKET_UE5_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_SONY_SOCKET_DEFAULT 0)
set(_REACTORMQ_SOCKET_WITH_LIB_WEBSOCKET_DEFAULT 1)

if (REACTORMQ_SSL_AVAILABLE)
    if (REACTORMQ_WITH_SOCKET_POLYFILL OR REACTORMQ_WITH_FSOCKET_UE5 OR REACTORMQ_WITH_O3DE_SOCKET)
        set(_REACTORMQ_SECURE_SOCKET_WITH_BIO_TLS_DEFAULT ON)
        message(STATUS "Secure socket implementation: BIO (for polyfill/UE5/O3DE platforms)")
    else()
        set(_REACTORMQ_SECURE_SOCKET_WITH_TLS_DEFAULT ON)
        message(STATUS "Secure socket implementation: Native (using socket descriptor)")
    endif()
else()
    message(STATUS "Secure socket implementation: DISABLED (TLS not available)")
endif()

option(REACTORMQ_SECURE_SOCKET_WITH_TLS "Platform has standard openssl socket" ${_REACTORMQ_SECURE_SOCKET_WITH_TLS_DEFAULT})
option(REACTORMQ_SECURE_SOCKET_WITH_BIO_TLS "Platform BIO openssl socket" ${_REACTORMQ_SECURE_SOCKET_WITH_BIO_TLS_DEFAULT})
